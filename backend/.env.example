# Port sur lequel le serveur API Node.js va écouter (interne)
PORT=3000

# Chemin d'accès absolu ou relatif vers la base de données SQLite du Dashboard
DATABASE_PATH=./database.db

# Mot de passe administrateur par défaut pour l'interface ZiVPN
ADMIN_PASSWORD=admin1234

# Chemin du fichier de configuration ZiVPN sur le serveur
ZIVPN_CONFIG_PATH=/etc/zivpn/config.json

# Nom de l'interface réseau principale à écouter (ex: eth0, enX0). Laissez vide pour auto-détection
NETWORK_INTERFACE=

# Limite mensuelle de transfert sortant en Go (ex: 100 pour l'offre gratuite AWS EC2)
EGRESS_LIMIT_GB=100

# --- CONFIGURATION DU BOT A ASSOCIER ---
# Nom du processus PM2 du bot à démarrer/arrêter/surveiller
BOT_PM2_NAME=whatsapp-bot

# Chemin absolu du fichier de logs standard de votre bot
BOT_LOGS_OUT_PATH=/home/ubuntu/.pm2/logs/whatsapp-bot-out.log

# Chemin absolu du fichier de logs d'erreurs de votre bot
BOT_LOGS_ERR_PATH=/home/ubuntu/.pm2/logs/whatsapp-bot-error.log
